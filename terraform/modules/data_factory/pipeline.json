{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "factoryName": { "type": "String" },
    "keyVaultBaseUrl": { "type": "String" },
    "sourceFileshareAccountName": { "type": "String" },
    "destFileshareAccountName": { "type": "String" },
    "sourceFileshareStorageResourceId": { "type": "String" },
    "destFileshareStorageResourceId": { "type": "String" },
    "checkpointStorageAccountName": { "type": "String" },
    "checkpointStorageResourceId": { "type": "String" },
    "checkpointContainerName": { "type": "String" },
    "checkpointCurrentPrefix": { "type": "String" },
    "checkpointJournalPrefix": { "type": "String" },
    "fileshareCheckpointBlobName": { "type": "String" },
    "datalakeCheckpointBlobName": { "type": "String" },
    "bootstrapWatermark": { "type": "String" },
    "deleteReconcileScheduleHours": { "type": "String" },
    "deleteReconcileTriggerStartTime": { "type": "String" },
    "sourceDatalakeAccountName": { "type": "String" },
    "destDatalakeAccountName": { "type": "String" },
    "sourceDatalakeFilesystem": { "type": "String" },
    "destDatalakeFilesystem": { "type": "String" }
  },
  "resources": [
    {
      "type": "Microsoft.DataFactory/factories/managedVirtualNetworks",
      "apiVersion": "2018-06-01",
      "name": "[concat(parameters('factoryName'), '/default')]",
      "properties": {}
    },
    {
      "type": "Microsoft.DataFactory/factories/managedVirtualNetworks/managedPrivateEndpoints",
      "apiVersion": "2018-06-01",
      "name": "[concat(parameters('factoryName'), '/default/adf-source-fileshare-pe')]",
      "dependsOn": [
        "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/managedVirtualNetworks/default')]"
      ],
      "properties": {
        "groupId": "file",
        "privateLinkResourceId": "[parameters('sourceFileshareStorageResourceId')]"
      }
    },
    {
      "type": "Microsoft.DataFactory/factories/managedVirtualNetworks/managedPrivateEndpoints",
      "apiVersion": "2018-06-01",
      "name": "[concat(parameters('factoryName'), '/default/adf-dest-fileshare-pe')]",
      "dependsOn": [
        "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/managedVirtualNetworks/default')]"
      ],
      "properties": {
        "groupId": "file",
        "privateLinkResourceId": "[parameters('destFileshareStorageResourceId')]"
      }
    },
    {
      "type": "Microsoft.DataFactory/factories/managedVirtualNetworks/managedPrivateEndpoints",
      "apiVersion": "2018-06-01",
      "name": "[concat(parameters('factoryName'), '/default/adf-checkpoint-pe')]",
      "dependsOn": [
        "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/managedVirtualNetworks/default')]"
      ],
      "properties": {
        "groupId": "blob",
        "privateLinkResourceId": "[parameters('checkpointStorageResourceId')]"
      }
    },
    {
      "type": "Microsoft.DataFactory/factories/integrationruntimes",
      "apiVersion": "2018-06-01",
      "name": "[concat(parameters('factoryName'), '/adf-managed-ir')]",
      "dependsOn": [
        "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/managedVirtualNetworks/default')]"
      ],
      "properties": {
        "type": "Managed",
        "managedVirtualNetworkReference": {
          "referenceName": "default",
          "type": "ManagedVirtualNetworkReference"
        },
        "typeProperties": {
          "computeProperties": {
            "location": "Canada East",
            "dataFlowProperties": {
              "computeType": "General",
              "coreCount": 8,
              "timeToLive": 10
            }
          }
        }
      }
    },
    {
      "type": "Microsoft.DataFactory/factories/linkedservices",
      "apiVersion": "2018-06-01",
      "name": "[concat(parameters('factoryName'), '/adf-keyvault')]",
      "properties": {
        "type": "AzureKeyVault",
        "typeProperties": {
          "baseUrl": "[parameters('keyVaultBaseUrl')]"
        }
      }
    },
    {
      "type": "Microsoft.DataFactory/factories/linkedservices",
      "apiVersion": "2018-06-01",
      "name": "[concat(parameters('factoryName'), '/source_fileshare')]",
      "dependsOn": [
        "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/integrationruntimes/adf-managed-ir')]"
      ],
      "properties": {
        "type": "AzureFileStorage",
        "connectVia": {
          "referenceName": "adf-managed-ir",
          "type": "IntegrationRuntimeReference"
        },
        "typeProperties": {
          "serviceEndpoint": "[concat('https://', parameters('sourceFileshareAccountName'), '.file.core.windows.net/')]",
          "fileShare": "fileshare"
        }
      }
    },
    {
      "type": "Microsoft.DataFactory/factories/linkedservices",
      "apiVersion": "2018-06-01",
      "name": "[concat(parameters('factoryName'), '/source_datalake')]",
      "properties": {
        "type": "AzureBlobFS",
        "connectVia": {
          "referenceName": "adf-managed-ir",
          "type": "IntegrationRuntimeReference"
        },
        "typeProperties": {
          "url": "[concat('https://', parameters('sourceDatalakeAccountName'), '.dfs.core.windows.net')]"
        }
      }
    },
    {
      "type": "Microsoft.DataFactory/factories/linkedservices",
      "apiVersion": "2018-06-01",
      "name": "[concat(parameters('factoryName'), '/dest_datalake')]",
      "properties": {
        "type": "AzureBlobFS",
        "connectVia": {
          "referenceName": "adf-managed-ir",
          "type": "IntegrationRuntimeReference"
        },
        "typeProperties": {
          "url": "[concat('https://', parameters('destDatalakeAccountName'), '.dfs.core.windows.net')]"
        }
      }
    },
    {
      "type": "Microsoft.DataFactory/factories/linkedservices",
      "apiVersion": "2018-06-01",
      "name": "[concat(parameters('factoryName'), '/dest_fileshare')]",
      "dependsOn": [
        "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/integrationruntimes/adf-managed-ir')]"
      ],
      "properties": {
        "type": "AzureFileStorage",
        "connectVia": {
          "referenceName": "adf-managed-ir",
          "type": "IntegrationRuntimeReference"
        },
        "typeProperties": {
          "serviceEndpoint": "[concat('https://', parameters('destFileshareAccountName'), '.file.core.windows.net/')]",
          "fileShare": "fileshare"
        }
      }
    },
    {
      "type": "Microsoft.DataFactory/factories/linkedservices",
      "apiVersion": "2018-06-01",
      "name": "[concat(parameters('factoryName'), '/checkpoint_storage')]",
      "dependsOn": [
        "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/integrationruntimes/adf-managed-ir')]"
      ],
      "properties": {
        "type": "AzureBlobStorage",
        "connectVia": {
          "referenceName": "adf-managed-ir",
          "type": "IntegrationRuntimeReference"
        },
        "typeProperties": {
          "serviceEndpoint": "[concat('https://', parameters('checkpointStorageAccountName'), '.blob.core.windows.net')]",
          "authenticationType": "ManagedIdentity"
        }
      }
    },
    {
      "type": "Microsoft.DataFactory/factories/datasets",
      "apiVersion": "2018-06-01",
      "name": "[concat(parameters('factoryName'), '/source_fileshare')]",
      "dependsOn": [
        "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/linkedservices/source_fileshare')]"
      ],
      "properties": {
        "parameters": {
          "folderPath": {
            "type": "String",
            "defaultValue": "/"
          },
          "fileName": {
            "type": "String",
            "defaultValue": ""
          }
        },
        "linkedServiceName": {
          "referenceName": "source_fileshare",
          "type": "LinkedServiceReference"
        },
        "type": "AzureFile",
        "typeProperties": {
          "folderPath": {
            "value": "@dataset().folderPath",
            "type": "Expression"
          },
          "fileName": {
            "value": "@dataset().fileName",
            "type": "Expression"
          }
        }
      }
    },
    {
      "type": "Microsoft.DataFactory/factories/datasets",
      "apiVersion": "2018-06-01",
      "name": "[concat(parameters('factoryName'), '/source_datalake')]",
      "dependsOn": [
        "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/linkedservices/source_datalake')]"
      ],
      "properties": {
        "parameters": {
          "folderPath": {
            "type": "String",
            "defaultValue": "[parameters('sourceDatalakeFilesystem')]"
          },
          "fileName": {
            "type": "String",
            "defaultValue": ""
          }
        },
        "linkedServiceName": {
          "referenceName": "source_datalake",
          "type": "LinkedServiceReference"
        },
        "type": "AzureBlobFSDataset",
        "typeProperties": {
          "folderPath": {
            "value": "@dataset().folderPath",
            "type": "Expression"
          },
          "fileName": {
            "value": "@dataset().fileName",
            "type": "Expression"
          }
        }
      }
    },
    {
      "type": "Microsoft.DataFactory/factories/datasets",
      "apiVersion": "2018-06-01",
      "name": "[concat(parameters('factoryName'), '/dest_datalake')]",
      "dependsOn": [
        "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/linkedservices/dest_datalake')]"
      ],
      "properties": {
        "parameters": {
          "folderPath": {
            "type": "String",
            "defaultValue": "[parameters('destDatalakeFilesystem')]"
          },
          "fileName": {
            "type": "String",
            "defaultValue": ""
          }
        },
        "linkedServiceName": {
          "referenceName": "dest_datalake",
          "type": "LinkedServiceReference"
        },
        "type": "AzureBlobFSDataset",
        "typeProperties": {
          "folderPath": {
            "value": "@dataset().folderPath",
            "type": "Expression"
          },
          "fileName": {
            "value": "@dataset().fileName",
            "type": "Expression"
          }
        }
      }
    },
    {
      "type": "Microsoft.DataFactory/factories/datasets",
      "apiVersion": "2018-06-01",
      "name": "[concat(parameters('factoryName'), '/dest_fileshare')]",
      "dependsOn": [
        "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/linkedservices/dest_fileshare')]"
      ],
      "properties": {
        "parameters": {
          "folderPath": {
            "type": "String",
            "defaultValue": "/"
          },
          "fileName": {
            "type": "String",
            "defaultValue": ""
          }
        },
        "linkedServiceName": {
          "referenceName": "dest_fileshare",
          "type": "LinkedServiceReference"
        },
        "type": "AzureFile",
        "typeProperties": {
          "folderPath": {
            "value": "@dataset().folderPath",
            "type": "Expression"
          },
          "fileName": {
            "value": "@dataset().fileName",
            "type": "Expression"
          }
        }
      }
    },
    {
      "type": "Microsoft.DataFactory/factories/datasets",
      "apiVersion": "2018-06-01",
      "name": "[concat(parameters('factoryName'), '/fileshare_checkpoint')]",
      "dependsOn": [
        "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/linkedservices/checkpoint_storage')]"
      ],
      "properties": {
        "linkedServiceName": {
          "referenceName": "checkpoint_storage",
          "type": "LinkedServiceReference"
        },
        "type": "Json",
        "typeProperties": {
          "location": {
            "type": "AzureBlobStorageLocation",
            "container": "[parameters('checkpointContainerName')]",
            "folderPath": "[parameters('checkpointCurrentPrefix')]",
            "fileName": "[parameters('fileshareCheckpointBlobName')]"
          },
          "format": {
            "type": "JsonFormat",
            "filePattern": "setOfObjects"
          }
        }
      }
    },
    {
      "type": "Microsoft.DataFactory/factories/datasets",
      "apiVersion": "2018-06-01",
      "name": "[concat(parameters('factoryName'), '/datalake_checkpoint')]",
      "dependsOn": [
        "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/linkedservices/checkpoint_storage')]"
      ],
      "properties": {
        "linkedServiceName": {
          "referenceName": "checkpoint_storage",
          "type": "LinkedServiceReference"
        },
        "type": "Json",
        "typeProperties": {
          "location": {
            "type": "AzureBlobStorageLocation",
            "container": "[parameters('checkpointContainerName')]",
            "folderPath": "[parameters('checkpointCurrentPrefix')]",
            "fileName": "[parameters('datalakeCheckpointBlobName')]"
          },
          "format": {
            "type": "JsonFormat",
            "filePattern": "setOfObjects"
          }
        }
      }
    },
    {
      "type": "Microsoft.DataFactory/factories/pipelines",
      "apiVersion": "2018-06-01",
      "name": "[concat(parameters('factoryName'), '/copyfilesharepipeline')]",
      "dependsOn": [
        "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/datasets/source_fileshare')]",
        "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/datasets/dest_fileshare')]",
        "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/datasets/fileshare_checkpoint')]"
      ],
      "properties": {
        "concurrency": 1,
        "parameters": {
          "checkpointStorageAccountName": {
            "type": "String",
            "defaultValue": "[parameters('checkpointStorageAccountName')]"
          },
          "checkpointContainerName": {
            "type": "String",
            "defaultValue": "[parameters('checkpointContainerName')]"
          },
          "checkpointCurrentPrefix": {
            "type": "String",
            "defaultValue": "[parameters('checkpointCurrentPrefix')]"
          },
          "fileshareCheckpointBlobName": {
            "type": "String",
            "defaultValue": "[parameters('fileshareCheckpointBlobName')]"
          }
        },
        "variables": {
          "bootstrapWatermark": {
            "type": "String",
            "defaultValue": "[parameters('bootstrapWatermark')]"
          },
          "runWindowStartUtc": {
            "type": "String"
          },
          "runWindowEndUtc": {
            "type": "String"
          }
        },
        "activities": [
          {
            "name": "SetRunWindowEnd",
            "type": "SetVariable",
            "dependsOn": [],
            "typeProperties": {
              "variableName": "runWindowEndUtc",
              "value": {
                "value": "@utcNow()",
                "type": "Expression"
              }
            }
          },
          {
            "name": "ReadCheckpoint",
            "type": "Lookup",
            "dependsOn": [
              {
                "activity": "SetRunWindowEnd",
                "dependencyConditions": [
                  "Succeeded"
                ]
              }
            ],
            "policy": {
              "timeout": "0.00:05:00",
              "retry": 1,
              "retryIntervalInSeconds": 30
            },
            "typeProperties": {
              "dataset": {
                "referenceName": "fileshare_checkpoint",
                "type": "DatasetReference"
              },
              "firstRowOnly": true
            }
          },
          {
            "name": "SetWindowStart",
            "type": "SetVariable",
            "dependsOn": [
              {
                "activity": "ReadCheckpoint",
                "dependencyConditions": [
                  "Succeeded",
                  "Failed",
                  "Skipped"
                ]
              }
            ],
            "typeProperties": {
              "variableName": "runWindowStartUtc",
              "value": {
                "value": "@if(or(empty(activity('ReadCheckpoint').output), empty(activity('ReadCheckpoint').output.firstRow), empty(activity('ReadCheckpoint').output.firstRow.lastSuccessfulWatermarkUtc)), variables('bootstrapWatermark'), activity('ReadCheckpoint').output.firstRow.lastSuccessfulWatermarkUtc)",
                "type": "Expression"
              }
            }
          },
          {
            "name": "CopyFiles",
            "type": "Copy",
            "dependsOn": [
              {
                "activity": "SetWindowStart",
                "dependencyConditions": [
                  "Succeeded"
                ]
              }
            ],
            "policy": {
              "timeout": "7.00:00:00",
              "retry": 0
            },
            "typeProperties": {
              "source": {
                "type": "FileSystemSource",
                "recursive": true,
                "modifiedDatetimeStart": {
                  "value": "@addSeconds(variables('runWindowStartUtc'), -30)",
                  "type": "Expression"
                },
                "modifiedDatetimeEnd": {
                  "value": "@variables('runWindowEndUtc')",
                  "type": "Expression"
                }
              },
              "sink": {
                "type": "FileSystemSink",
                "copyBehavior": "PreserveHierarchy"
              },
              "enableStaging": false,
              "validateDataConsistency": false,
              "logSettings": {
                "enableCopyActivityLog": true,
                "copyActivityLogSettings": {
                  "logLevel": "Warning",
                  "enableReliableLogging": false
                },
                "logLocationSettings": {
                  "linkedServiceName": {
                    "referenceName": "checkpoint_storage",
                    "type": "LinkedServiceReference"
                  },
                  "path": "[concat(parameters('checkpointContainerName'), '/', parameters('checkpointJournalPrefix'), '/copyfilesharepipeline/logs')]"
                }
              },
              "skipErrorFile": {
                "fileMissing": true
              }
            },
            "inputs": [
              {
                "referenceName": "source_fileshare",
                "type": "DatasetReference"
              }
            ],
            "outputs": [
              {
                "referenceName": "dest_fileshare",
                "type": "DatasetReference"
              }
            ]
          },
          {
            "name": "WriteCheckpoint",
            "type": "WebActivity",
            "dependsOn": [
              {
                "activity": "CopyFiles",
                "dependencyConditions": [
                  "Succeeded"
                ]
              }
            ],
            "connectVia": {
              "referenceName": "adf-managed-ir",
              "type": "IntegrationRuntimeReference"
            },
            "policy": {
              "retry": 3,
              "retryIntervalInSeconds": 30
            },
            "typeProperties": {
              "method": "PUT",
              "url": {
                "value": "@concat('https://', pipeline().parameters.checkpointStorageAccountName, '.blob.core.windows.net/', pipeline().parameters.checkpointContainerName, '/', pipeline().parameters.checkpointCurrentPrefix, '/', pipeline().parameters.fileshareCheckpointBlobName)",
                "type": "Expression"
              },
              "headers": {
                "x-ms-blob-type": "BlockBlob",
                "x-ms-version": "2023-11-03",
                "Content-Type": "application/json"
              },
              "body": {
                "value": "@concat('{', '\"schemaVersion\":\"1\",', '\"pipelineName\":\"copyfilesharepipeline\",', '\"lastSuccessfulWatermarkUtc\":\"', variables('runWindowEndUtc'), '\",', '\"lastRunId\":\"', pipeline().RunId, '\",', '\"lastRunStatus\":\"succeeded\",', '\"lastRunEndedUtc\":\"', utcNow(), '\"', '}')",
                "type": "Expression"
              },
              "authentication": {
                "type": "MSI",
                "resource": "https://storage.azure.com/"
              }
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.DataFactory/factories/pipelines",
      "apiVersion": "2018-06-01",
      "name": "[concat(parameters('factoryName'), '/copydatalakegen2pipeline')]",
      "dependsOn": [
        "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/datasets/source_datalake')]",
        "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/datasets/dest_datalake')]",
        "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/datasets/datalake_checkpoint')]"
      ],
      "properties": {
        "concurrency": 1,
        "parameters": {
          "checkpointStorageAccountName": {
            "type": "String",
            "defaultValue": "[parameters('checkpointStorageAccountName')]"
          },
          "checkpointContainerName": {
            "type": "String",
            "defaultValue": "[parameters('checkpointContainerName')]"
          },
          "checkpointCurrentPrefix": {
            "type": "String",
            "defaultValue": "[parameters('checkpointCurrentPrefix')]"
          },
          "datalakeCheckpointBlobName": {
            "type": "String",
            "defaultValue": "[parameters('datalakeCheckpointBlobName')]"
          }
        },
        "variables": {
          "bootstrapWatermark": {
            "type": "String",
            "defaultValue": "[parameters('bootstrapWatermark')]"
          },
          "runWindowStartUtc": {
            "type": "String"
          },
          "runWindowEndUtc": {
            "type": "String"
          }
        },
        "activities": [
          {
            "name": "SetRunWindowEnd",
            "type": "SetVariable",
            "dependsOn": [],
            "typeProperties": {
              "variableName": "runWindowEndUtc",
              "value": {
                "value": "@utcNow()",
                "type": "Expression"
              }
            }
          },
          {
            "name": "ReadCheckpoint",
            "type": "Lookup",
            "dependsOn": [
              {
                "activity": "SetRunWindowEnd",
                "dependencyConditions": [
                  "Succeeded"
                ]
              }
            ],
            "policy": {
              "timeout": "0.00:05:00",
              "retry": 1,
              "retryIntervalInSeconds": 30
            },
            "typeProperties": {
              "dataset": {
                "referenceName": "datalake_checkpoint",
                "type": "DatasetReference"
              },
              "firstRowOnly": true
            }
          },
          {
            "name": "SetWindowStart",
            "type": "SetVariable",
            "dependsOn": [
              {
                "activity": "ReadCheckpoint",
                "dependencyConditions": [
                  "Succeeded",
                  "Failed",
                  "Skipped"
                ]
              }
            ],
            "typeProperties": {
              "variableName": "runWindowStartUtc",
              "value": {
                "value": "@if(or(empty(activity('ReadCheckpoint').output), empty(activity('ReadCheckpoint').output.firstRow), empty(activity('ReadCheckpoint').output.firstRow.lastSuccessfulWatermarkUtc)), variables('bootstrapWatermark'), activity('ReadCheckpoint').output.firstRow.lastSuccessfulWatermarkUtc)",
                "type": "Expression"
              }
            }
          },
          {
            "name": "CopyDataLakeGen2",
            "type": "Copy",
            "dependsOn": [
              {
                "activity": "SetWindowStart",
                "dependencyConditions": [
                  "Succeeded"
                ]
              }
            ],
            "policy": {
              "timeout": "7.00:00:00",
              "retry": 0
            },
            "typeProperties": {
              "source": {
                "type": "AzureBlobFSSource",
                "recursive": true,
                "modifiedDatetimeStart": {
                  "value": "@addSeconds(variables('runWindowStartUtc'), -30)",
                  "type": "Expression"
                },
                "modifiedDatetimeEnd": {
                  "value": "@variables('runWindowEndUtc')",
                  "type": "Expression"
                }
              },
              "sink": {
                "type": "AzureBlobFSSink",
                "copyBehavior": "PreserveHierarchy"
              },
              "enableStaging": false,
              "logSettings": {
                "enableCopyActivityLog": true,
                "copyActivityLogSettings": {
                  "logLevel": "Warning",
                  "enableReliableLogging": false
                },
                "logLocationSettings": {
                  "linkedServiceName": {
                    "referenceName": "checkpoint_storage",
                    "type": "LinkedServiceReference"
                  },
                  "path": "[concat(parameters('checkpointContainerName'), '/', parameters('checkpointJournalPrefix'), '/copydatalakegen2pipeline/logs')]"
                }
              },
              "skipErrorFile": {
                "fileMissing": true
              }
            },
            "inputs": [
              {
                "referenceName": "source_datalake",
                "type": "DatasetReference"
              }
            ],
            "outputs": [
              {
                "referenceName": "dest_datalake",
                "type": "DatasetReference"
              }
            ]
          },
          {
            "name": "WriteCheckpoint",
            "type": "WebActivity",
            "dependsOn": [
              {
                "activity": "CopyDataLakeGen2",
                "dependencyConditions": [
                  "Succeeded"
                ]
              }
            ],
            "connectVia": {
              "referenceName": "adf-managed-ir",
              "type": "IntegrationRuntimeReference"
            },
            "policy": {
              "retry": 3,
              "retryIntervalInSeconds": 30
            },
            "typeProperties": {
              "method": "PUT",
              "url": {
                "value": "@concat('https://', pipeline().parameters.checkpointStorageAccountName, '.blob.core.windows.net/', pipeline().parameters.checkpointContainerName, '/', pipeline().parameters.checkpointCurrentPrefix, '/', pipeline().parameters.datalakeCheckpointBlobName)",
                "type": "Expression"
              },
              "headers": {
                "x-ms-blob-type": "BlockBlob",
                "x-ms-version": "2023-11-03",
                "Content-Type": "application/json"
              },
              "body": {
                "value": "@concat('{', '\"schemaVersion\":\"1\",', '\"pipelineName\":\"copydatalakegen2pipeline\",', '\"lastSuccessfulWatermarkUtc\":\"', variables('runWindowEndUtc'), '\",', '\"lastRunId\":\"', pipeline().RunId, '\",', '\"lastRunStatus\":\"succeeded\",', '\"lastRunEndedUtc\":\"', utcNow(), '\"', '}')",
                "type": "Expression"
