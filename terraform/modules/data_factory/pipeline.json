{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "factoryName": { "type": "String" },
    "sourceConnectionString": { "type": "String" },
    "destConnectionString": { "type": "String" }
    ,
    "sourceDatalakeAccountName": { "type": "String" },
    "destDatalakeAccountName": { "type": "String" },
    "sourceDatalakeFilesystem": { "type": "String" },
    "destDatalakeFilesystem": { "type": "String" }
  },
  "resources": [
    
    { "type": "Microsoft.DataFactory/factories/linkedservices", "apiVersion": "2018-06-01", "name": "[concat(parameters('factoryName'), '/source-fileshare')]", "properties": { "type": "AzureFileStorage", "typeProperties": { "connectionString": "[parameters('sourceConnectionString')]", "fileShare": "fileshare" } } },
    { "type": "Microsoft.DataFactory/factories/linkedservices", "apiVersion": "2018-06-01", "name": "[concat(parameters('factoryName'), '/source-datalake')]", "properties": { "type": "AzureBlobFS", "typeProperties": { "url": "[concat('https://', parameters('sourceDatalakeAccountName'), '.dfs.core.windows.net')]" } } },
    { "type": "Microsoft.DataFactory/factories/linkedservices", "apiVersion": "2018-06-01", "name": "[concat(parameters('factoryName'), '/dest-datalake')]", "properties": { "type": "AzureBlobFS", "typeProperties": { "url": "[concat('https://', parameters('destDatalakeAccountName'), '.dfs.core.windows.net')]" } } },
    { "type": "Microsoft.DataFactory/factories/linkedservices", "apiVersion": "2018-06-01", "name": "[concat(parameters('factoryName'), '/dest-fileshare')]", "properties": { "type": "AzureFileStorage", "typeProperties": { "connectionString": "[parameters('destConnectionString')]", "fileShare": "fileshare" } } },

    
    { "type": "Microsoft.DataFactory/factories/datasets", "apiVersion": "2018-06-01", "name": "[concat(parameters('factoryName'), '/source-fileshare')]", "dependsOn": ["[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/linkedservices/source-fileshare')]"], "properties": { "linkedServiceName": { "referenceName": "source-fileshare", "type": "LinkedServiceReference" }, "type": "AzureFile", "typeProperties": { "folderPath": "/" } } },
    { "type": "Microsoft.DataFactory/factories/datasets", "apiVersion": "2018-06-01", "name": "[concat(parameters('factoryName'), '/source-datalake')]", "dependsOn": ["[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/linkedservices/source-datalake')]"], "properties": { "linkedServiceName": { "referenceName": "source-datalake", "type": "LinkedServiceReference" }, "type": "AzureBlobFSDataset", "typeProperties": { "folderPath": "[parameters('sourceDatalakeFilesystem')]" } } },
    { "type": "Microsoft.DataFactory/factories/datasets", "apiVersion": "2018-06-01", "name": "[concat(parameters('factoryName'), '/dest-datalake')]", "dependsOn": ["[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/linkedservices/dest-datalake')]"], "properties": { "linkedServiceName": { "referenceName": "dest-datalake", "type": "LinkedServiceReference" }, "type": "AzureBlobFSDataset", "typeProperties": { "folderPath": "[parameters('destDatalakeFilesystem')]" } } },
    { "type": "Microsoft.DataFactory/factories/datasets", "apiVersion": "2018-06-01", "name": "[concat(parameters('factoryName'), '/dest-fileshare')]", "dependsOn": ["[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/linkedservices/dest-fileshare')]"], "properties": { "linkedServiceName": { "referenceName": "dest-fileshare", "type": "LinkedServiceReference" }, "type": "AzureFile", "typeProperties": { "folderPath": "/" } } },

    
    { "type": "Microsoft.DataFactory/factories/pipelines", "apiVersion": "2018-06-01", "name": "[concat(parameters('factoryName'), '/copyfilesharepipeline')]", "dependsOn": ["[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/datasets/source-fileshare')]", "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/datasets/dest-fileshare')]"], "properties": { "activities": [ { "name": "CopyFiles", "type": "Copy", "dependsOn": [], "policy": {}, "typeProperties": { "source": { "type": "FileSystemSource" }, "sink": { "type": "FileSystemSink" } }, "inputs": [ { "referenceName": "source-fileshare", "type": "DatasetReference" } ], "outputs": [ { "referenceName": "dest-fileshare", "type": "DatasetReference" } ] } ] } },
    { "type": "Microsoft.DataFactory/factories/pipelines", "apiVersion": "2018-06-01", "name": "[concat(parameters('factoryName'), '/copydatalakegen2pipeline')]", "dependsOn": ["[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/datasets/source-datalake')]", "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/datasets/dest-datalake')]"], "properties": { "activities": [ { "name": "CopyDataLakeGen2", "type": "Copy", "dependsOn": [], "policy": {}, "typeProperties": { "source": { "type": "AzureBlobFSSource" }, "sink": { "type": "AzureBlobFSSink" } }, "inputs": [ { "referenceName": "source-datalake", "type": "DatasetReference" } ], "outputs": [ { "referenceName": "dest-datalake", "type": "DatasetReference" } ] } ] } },

    
    { "type": "Microsoft.DataFactory/factories/triggers", "apiVersion": "2018-06-01", "name": "[concat(parameters('factoryName'), '/copyfilesharetrigger')]", "dependsOn": ["[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/pipelines/copyfilesharepipeline')]"], "properties": { "type": "ScheduleTrigger", "typeProperties": { "recurrence": { "frequency": "Minute", "interval": 5, "startTime": "2026-03-02T12:00:00Z" } }, "pipelines": [ { "pipelineReference": { "referenceName": "copyfilesharepipeline", "type": "PipelineReference" } } ] } },
    { "type": "Microsoft.DataFactory/factories/triggers", "apiVersion": "2018-06-01", "name": "[concat(parameters('factoryName'), '/copydatalakegen2trigger')]", "dependsOn": ["[concat('Microsoft.DataFactory/factories/', parameters('factoryName'), '/pipelines/copydatalakegen2pipeline')]"], "properties": { "type": "ScheduleTrigger", "typeProperties": { "recurrence": { "frequency": "Minute", "interval": 5, "startTime": "2026-03-02T12:00:00Z" } }, "pipelines": [ { "pipelineReference": { "referenceName": "copydatalakegen2pipeline", "type": "PipelineReference" } } ] } }
  ]
}
